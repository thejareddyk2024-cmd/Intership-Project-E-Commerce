# ──────────────────────────────────────────────────
# ShopSmart-AI Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────

# Backend
DATABASE_URL=postgresql://shopsmart:shopsmart_pass@localhost:5432/shopsmart
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Service (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Redis (optional — app works without it)
REDIS_URL=redis://localhost:6379/0

# Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173,http://localhost:3000

# Docker Compose uses these values automatically
# POSTGRES_USER=shopsmart
# POSTGRES_PASSWORD=shopsmart_pass
# POSTGRES_DB=shopsmart
